# ============================================================
# Barbershop Template — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ---- Supabase (optional — for persistent appointment storage) ----
# Create a free project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Shop identity ----
# Set this to the slug defined in config/master-shop.ts
NEXT_PUBLIC_SHOP_SLUG=elite-barber-studio

# ---- Twilio (SMS notifications to barbers on new bookings) ----
# Sign up at https://twilio.com — free trial available
# Add each barber's phone number (E.164 format) to their profile in config/master-shop.ts
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# The Twilio phone number you purchased (E.164 format, e.g. +18005551234)
TWILIO_FROM_NUMBER=+18005551234

# ---- Resend (email confirmations to customers and barbers) ----
# Sign up at https://resend.com — free tier: 3,000 emails/month
# You must verify your sending domain in the Resend dashboard
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Verified sender address on your domain (e.g. bookings@yourdomain.com)
RESEND_FROM_ADDRESS=bookings@yourdomain.com
